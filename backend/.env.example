# Backend environment variables for development and production
# Copy this file to .env and set your real values.

# The port the backend server listens on
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/noor-ecommerce

# API URL used by backend-generated full URLs (uploads, email links, etc.)
API_URL=http://localhost:5000

# Frontend URL used in email links and password resets
FRONTEND_URL=http://localhost:3000

# JWT secret for authentication
JWT_SECRET=your-secret-key

# Comma-separated allowed CORS origins for production and development.
# Example production value:
# ALLOWED_ORIGINS=https://alfanar.store,https://www.alfanar.store
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002,https://alfanar.store,https://www.alfanar.store

# Redis configuration - use REDIS_URL for connection string (recommended)
# For Redis Cloud or remote: REDIS_URL=redis://default:PASSWORD@HOST:PORT
# For local Redis: REDIS_URL=redis://localhost:6379
REDIS_URL=redis://localhost:6379

# OR use individual config (if REDIS_URL not set):
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
